# ============================================================
# Person Identification System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=personid_db
POSTGRES_USER=personid_user
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=personid_rabbit
RABBITMQ_PASSWORD=change_me_rabbit_password
RABBITMQ_VHOST=/

# ── .NET Core API ─────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
UPLOAD_BASE_PATH=/app/uploads

# ── Python Face Recognition Service ───────────────────────
FACE_RECOGNITION_PORT=8000
FACE_RECOGNITION_MODEL=arcface
CONFIDENCE_THRESHOLD=0.85
MODEL_CACHE_DIR=/app/models

# ── Python Stream Processor ───────────────────────────────
STREAM_PROCESSOR_PORT=8001
FRAME_INTERVAL_SECONDS=5
MAX_CONCURRENT_STREAMS=10
DOTNET_API_URL=http://api:5000

# ── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
FROM_EMAIL=alerts@yoursystem.com
FROM_NAME=Person Identification System

# ── Angular Frontend ──────────────────────────────────────
ANGULAR_PORT=4200
API_BASE_URL=http://localhost:5000/api
